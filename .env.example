# ===========================================
# JBR Environment Variables
# Copy this file to .env.local and fill in your values
# ===========================================

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/jualbeliraket"

# Better Auth
BETTER_AUTH_SECRET="generate-a-random-secret-key-min-32-chars"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# OAuth Providers (Optional - get from respective developer consoles)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

TWITTER_CLIENT_ID=""
TWITTER_CLIENT_SECRET=""

INSTAGRAM_CLIENT_ID=""
INSTAGRAM_CLIENT_SECRET=""

# TikTok native provider (Better Auth)
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
NEXT_PUBLIC_ENABLE_TIKTOK_LOGIN="false"

# UploadThing (get from https://uploadthing.com/dashboard)
UPLOADTHING_TOKEN=""

# ===========================================
# KYC OCR (optional, feature-flagged, local LLM)
# ===========================================
# Pre-screens KYC KTP images via a local OpenAI-compatible multimodal LLM
# (e.g. a llama.cpp server running Gemma 4). It reads the NIK off the card and
# cross-checks it against the seller-typed NIK. ADVISORY only — never changes
# KYC status. Leave KYC_OCR_LLM_URL empty to disable entirely.
#
# Turn the feature ON in two layers:
#   1) Endpoint config below (URL + model), AND
#   2) Feature flag "kyc.ocr" — toggle in Admin → Feature Flags, or force here:
#        FEATURE_KYC_OCR="force-on"   (or "force-off")
#
# Full chat-completions URL (NOT just the host). Empty = OCR disabled.
KYC_OCR_LLM_URL=""                      # e.g. http://10.0.28.77:8080/v1/chat/completions
KYC_OCR_LLM_MODEL=""                    # e.g. gemma-4-26b-a4b
KYC_OCR_LLM_API_KEY=""                  # optional bearer token (leave empty if none)
KYC_OCR_TIMEOUT_MS="90000"              # per-call timeout (ms)
KYC_OCR_MAX_TOKENS="1024"               # completion budget (model emits reasoning tokens too)
KYC_OCR_MAX_DIM="1400"                  # downscale longest image edge before sending (px)
KYC_OCR_BATCH="3"                       # submissions processed per sweep run
KYC_OCR_SWEEP_BUDGET_MS="120000"        # max wall-clock per sweep run (ms)
# FEATURE_KYC_OCR="force-on"            # env override for the kyc.ocr feature flag
# FEATURE_AFFILIATE_OCR="force-on"      # same, for affiliate-enrollment KTP OCR (flag "affiliate.ocr")

# OCR runs AUTOMATICALLY in the background right after a KYC submission (no cron
# needed for the happy path). The cron route below is a retry/backstop for kicks
# that died mid-flight (app restart, LLM down) — recommended but optional:
#   */5 * * * *  curl -fsS -X POST -H "Authorization: Bearer $CRON_SECRET" \
#                  https://jualbeliraket.com/api/cron/kyc-ocr
